vvrnailss.ru, www.vvrnailss.ru {
  handle /health* {
    reverse_proxy api:4000
  }

  handle /api/* {
    reverse_proxy api:4000
  }

  handle /launch* {
    header Cache-Control "no-store"
    reverse_proxy api:4000
  }

  handle /uploads/* {
    reverse_proxy api:4000
  }

  handle /assets/* {
    root * /srv
    header Cache-Control "public, max-age=31536000, immutable"
    file_server
  }

  handle {
    root * /srv
    header Cache-Control "no-store"
    try_files {path} /index.html
    file_server
  }
}
